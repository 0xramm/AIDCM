{
  "_version": "1.86.0",
  "sap.app": {
    "id": "aidcm",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "resources": "resources.json",
    "sourceTemplate": {
      "id": "@sap/generator-fiori:basic",
      "version": "1.28.0",
      "toolsId": "034ce29f-3e63-4a80-8f11-151142376b11"
    },
    "dataSources": {
      "admin": {
        "uri": "/odata/v4/admin/",
        "type": "OData",
        "settings": {
          "odataVersion": "4.0"
        }
      },
      "auth": {
        "uri": "/odata/v4/auth/",
        "type": "OData",
        "settings": {
          "odataVersion": "4.0"
        }
      },
      "review": {
        "uri": "/odata/v4/review/",
        "type": "OData",
        "settings": {
          "odataVersion": "4.0"
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": true,
    "dependencies": {
      "minUI5Version": "1.150.0",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.f": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "aidcm.i18n.i18n"
        }
      },
      "admin": {
        "type": "sap.ui.model.odata.v4.ODataModel",
        "dataSource": "admin",
        "settings": {
          "synchronizationMode": "None",
          "operationMode": "Server",
          "autoExpandSelect": true,
          "earlyRequests": false
        }
      },
      "auth": {
        "type": "sap.ui.model.odata.v4.ODataModel",
        "dataSource": "auth",
        "settings": {
          "synchronizationMode": "None",
          "operationMode": "Server"
        }
      },
      "review": {
        "type": "sap.ui.model.odata.v4.ODataModel",
        "dataSource": "review",
        "settings": {
          "synchronizationMode": "None",
          "operationMode": "Server",
          "autoExpandSelect": true,
          "earlyRequests": false
        }
      }
    },
    "resources": {
      "css": [
        {
          "uri": "css/style.css"
        }
      ]
    },
    "routing": {
      "config": {
        "routerClass": "sap.m.routing.Router",
        "controlAggregation": "pages",
        "controlId": "app",
        "transition": "slide",
        "type": "View",
        "viewType": "XML",
        "path": "aidcm.view",
        "async": true,
        "viewPath": "aidcm.view"
      },
      "routes": [
        {
          "name": "RouteLogin",
          "pattern": "",
          "target": ["TargetLogin"]
        },
        {
          "name": "RouteAdmin",
          "pattern": "admin",
          "target": ["TargetAdmin"]
        },
        {
          "name": "RouteReview",
          "pattern": "review/{level}",
          "target": ["TargetReview"]
        }
      ],
      "targets": {
        "TargetLogin": {
          "id": "Login",
          "name": "Login"
        },
        "TargetAdmin": {
          "id": "Admin",
          "name": "Admin"
        },
        "TargetReview": {
          "id": "Reviewer",
          "name": "Reviewer"
        }
      }
    },
    "rootView": {
      "viewName": "aidcm.view.App",
      "type": "XML",
      "id": "App",
      "async": true
    }
  }
}
